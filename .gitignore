# ============================================
# Face Blur Pipeline — .gitignore
# ============================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ---------- OS ----------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ---------- Project-specific ----------

# Pipeline output (generated files should not be tracked)
output/

# Model weights — large binary files, download at runtime
models/*.onnx
models/*.pth
models/*.caffemodel
models/*.pb

# Media files — test/sample inputs should not be committed
*.mp4
*.avi
*.mov
*.mkv
*.webm
*.flv
*.wmv

# Logs
*.log
logs/

# Temp files created during video processing
_fb_temp_*

# Jupyter / notebooks (if used for experimentation)
.ipynb_checkpoints/

# Coverage and test artifacts
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
nosetests.xml
coverage.xml

# Frontend
node_modules/
dist/
.env*
*.local

